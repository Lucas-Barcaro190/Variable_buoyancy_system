--
sysStatus = FATAL_ERROR_E02
currentVolume = UNKNOWN
lastHeartbeat = 15429837
--
[Waiting for manual RESET]

driver_instance: MotorDriver_Interface
--
isEnabled = FALSE
uartID = uart1
--
[Output: Driver Disabled]

feedback_instance: FeedbackSystem
--
minLimitHit = TRUE
potValue = 43 // MINIMAL_THRESHOLD</panel_attributes><additional_attributes></additional_attributes></element><element><id>UMLClass</id><coordinates><x>396</x><y>1122</y><w>462</w><h>385</h></coordinates><panel_attributes>// Estado de Emergência por perda de link com o PC
vbs_inst: VBS_Controller
--
sysStatus = FAILSAFE_ASCENT
currentVolume = 0.0 // cm3 (Posição intermediária no momento da falha)
targetVolume = 150.0 // cm3 (Forçado para expansão máxima)
lastHeartbeat = 1715615000 // &gt; 300s atrás
powerWarning = TRUE // Movimento longo exige alerta de carga
--
[Action: Emergency surfacing initiated]

driver_inst: MotorDriver_Interface
--
isEnabled = TRUE
currentSpeed = 2 // Velocidade nominal de torque máximo
direction = 0 // Expand
lastCommand = "MOVE_UNTIL_POT (AUTO)"
uartID = uart1

feedback_inst: FeedbackSystem
--
potValue = 240 // Iniciando subida
minLimitHit = FALSE
maxLimitHit = FALSE
uncertainty = ±2 // Pulsos</panel_attributes><additional_attributes></additional_attributes></element><element><id>UMLClass</id><coordinates><x>880</x><y>1122</y><w>352</w><h>385</h></coordinates><panel_attributes>// Estado de bloqueio total após atingir fim de curso
vbs_inst: VBS_Controller
--
sysStatus = CRITICAL_ERROR_E02
currentVolume = -150.0 // Teoricamente no mínimo
targetVolume = -150.0 
lastHeartbeat = 1715616500
powerWarning = FALSE
--
[Action: Driver Disabled to prevent mechanical damage]

driver_inst: MotorDriver_Interface
--
isEnabled = FALSE // "Corte de energia" via software
currentSpeed = 0
direction = 1 // Estava contraindo
lastCommand = "STOP (HARDWARE INTERRUPT)"
uartID = uart1

feedback_inst: FeedbackSystem
--
potValue = 43 // SW_MIN_LIMIT atingido
minLimitHit = TRUE
maxLimitHit = FALSE
uncertainty = 0 // Leitura de switch é absoluta</panel_attributes><additional_attributes></additional_attributes></element><element><id>UMLClass</id><coordinates><x>11</x><y>1122</y><w>363</w><h>385</h></coordinates><panel_attributes>vbs_inst: VBS_Controller
--
sysStatus = OPERATIONAL
currentVolume = 150.0 // cm3
targetVolume = 150.0 // cm3
lastHeartbeat = 1715615300 // Timestamp recente
powerWarning = FALSE
--
[System is stable and holding position]

// Instância do Driver em modo de economia/espera
driver_inst: MotorDriver_Interface
--
isEnabled = TRUE
currentSpeed = 0
lastCommand = "STOP"
uartID = uart1

// Sensores dentro da zona de trabalho segura
feedback_inst: FeedbackSystem
--
potValue = 240 // Valor médio (fora dos limites 43 e 435)
minLimitHit = FALSE
maxLimitHit = FALSE
uncertainty = ±2 // Pulsos

