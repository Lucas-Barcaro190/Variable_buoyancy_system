--
Responsibilities
-- Bloquear movimentos perigosos
-- Notificar PC (UART0)</panel_attributes><additional_attributes></additional_attributes></element><element><id>UMLSequenceAllInOne</id><coordinates><x>0</x><y>5731</y><w>1078</w><h>968</h></coordinates><panel_attributes>title=Sequence Diagram VBS (Exception Handling - Scenarios A &amp; B)
obj=Lifeline Computador~a
obj=Lifeline VBS_Pico:vParserTask~b
obj=Lifeline VBS_Pico:vPotentiometerTask~c
obj=Lifeline Driver_Motor~d

combinedFragment=alt~altStall b d; b:[Cenário A: Stall Detectado]
    b-&gt;b+1: 1: Timer &gt; 2X (Sem delta Pot);on=d
    b-&gt;&gt;&gt;d : 2: UART1: 0xF7 (STOP); off=d
    b-&gt;&gt;&gt;a : 3: Erro E03 (Stall Mecânico); on=a
    a.&gt;b : 4: ACK Error; off=a
--=altStall

tick=3

combinedFragment=alt~altSwitch d b; d:[Cenário B: Limit Switch ISR]
    d-&gt;&gt;&gt;b : 5: Hardware Interrupt (Falling Edge);on=d
    b-&gt;&gt;&gt;d : 6: UART1: 0xF7 (STOP)
    b-&gt;&gt;&gt;d : 7: UART1: Return 1mm
    b-&gt;b+1: 8: sysFault = TRUE and sysError = SWLIMIT
    b-&gt;&gt;&gt;a : 9: Erro E02 (Mechanical Limit Hit); on=a
    a.&gt;b : 10: ACK Error; off=a
    b-&gt;&gt;&gt;d : 11: PIN_ENABLE_DRIVER = HIGH (Disable);off=d
--=altSwitch</panel_attributes><additional_attributes></additional_attributes></element><element><id>UMLSequenceAllInOne</id><coordinates><x>220</x><y>2486</y><w>1551</w><h>1364</h></coordinates><panel_attributes>title=Sequence Diagram VBS (Optimized with Guard Clauses)
obj=Lifeline Computador~a
obj=Lifeline VBS_Pico:vParserTask~b
obj=Lifeline VBS_Pico:vPotentiometerTask~c
obj=Lifeline Driver_Motor~d

a-&gt;&gt;&gt;b : 1: CMD_VOL (cm3); on=b
b-&gt;b+1: 2: Validar Checksum; on=b

// Guard Clause: Trata o erro imediatamente e para o fluxo
combinedFragment=alt~altGuard b a; b:[Checksum Erro]
    b-&gt;&gt;&gt;a : 3: Erro E01 (Comms Failure); on=a
    a.&gt;b : 4: ACK Error; off=a
    b-&gt;b+1: Encerra Processamento
--=altGuard

// A partir daqui, o Checksum já é garantido como OK
b-&gt;&gt;&gt;c : 5: Get currentPot; on=c
c.&gt;b : 6: return pot; off=c

b-&gt;b+1: 7: Calcular Pulsos; on=b

b-&gt;&gt;&gt;a : 8: Power Warning; on=a
a.&gt;b : 9: ACK Warning; off=a

b-&gt;&gt;&gt;d : 10: UART1: 0xF6 (MOVE, v=2); on=d

combinedFragment=loop~loop1 b c; b:[Enquanto pot != target]
    c-&gt;&gt;&gt;b : 11: Update Pot (10Hz); on=b
    b.&gt;c : 12: Processed; off=b;on=d
    
    // Tratamento de interrupções físicas e lógicas
    combinedFragment=alt~altFaults b d; b:[Stall/Limit]
        b:[Watchdog Stall]
        b-&gt;&gt;&gt;d : 13: UART1: 0xF7 (STOP)
        b-&gt;&gt;&gt;a : 14: Erro E03; on=a
        
        ..=altFaults; d:[Limit Switch]
        d-&gt;&gt;&gt;b : 15: Interrupt; on=b
        b-&gt;&gt;&gt;d : 16: UART1: 0xF7 (STOP); off=d
        b-&gt;&gt;&gt;a : 17: Erro E02; on=a
    --=altFaults
--=loop1

b-&gt;&gt;&gt;d : 18: UART1: 0xF7 (STOP);off=d
b-&gt;&gt;&gt;a : 19: Sucesso (Posição); on=a
a.&gt;b : 20: ACK Success; off=a

off=b</panel_attributes><additional_attributes></additional_attributes></element><element><id>UMLSequenceAllInOne</id><coordinates><x>11</x><y>4873</y><w>1254</w><h>825</h></coordinates><panel_attributes>title=Sequence Diagram VBS (Happy Path)
obj=Lifeline Computador~a
obj=Lifeline VBS_Pico:vParserTask~b
obj=Lifeline VBS_Pico:vPotentiometerTask~c
obj=Lifeline Driver_Motor~d

a-&gt;&gt;&gt;b : 1: CMD_VOL (cm3); on=b

b-&gt;b +1: 2: Validar Checksum; on=b

b-&gt;&gt;&gt;c : 3: Get currentPot; on=c
c.&gt;b : 4: return pot; off=c

b-&gt;b+1: 5: Calcular Pulsos; on=b

b-&gt;&gt;&gt;a : 6: Power Warning; on=a
a.&gt;b : 7: ACK Warning; off=a

b-&gt;&gt;&gt;d : 8: UART1: 0xF6 (MOVE, v=2); on=d

combinedFragment=loop~loop1 b c; b:[Enquanto pot != target]
    c-&gt;&gt;&gt;b : 9: Update Pot (10Hz); on=b
    b.&gt;c : 10: Processed; off=b
--=loop1

b-&gt;&gt;&gt;d : 11: UART1: 0xF7 (STOP); off=d
b-&gt;&gt;&gt;a : 12: Sucesso (Posição); on=a
a.&gt;b : 13: ACK Success; off=a

off=b</panel_attributes><additional_attributes></additional_attributes></element><element><id>UMLState</id><coordinates><x>11</x><y>1870</y><w>99</w><h>44</h></coordinates><panel_attributes>initial_state
