</panel_attributes><additional_attributes>10;10;10;400;520;400;520;520</additional_attributes></element><element><id>Relation</id><coordinates><x>979</x><y>110</y><w>352</w><h>253</h></coordinates><panel_attributes>lt=&lt;-</panel_attributes><additional_attributes>300;10;170;10;170;210;10;210</additional_attributes></element><element><id>Relation</id><coordinates><x>979</x><y>352</y><w>352</w><h>33</h></coordinates><panel_attributes>lt=&lt;-</panel_attributes><additional_attributes>300;10;10;10</additional_attributes></element><element><id>Relation</id><coordinates><x>979</x><y>374</y><w>352</w><h>242</h></coordinates><panel_attributes>lt=&lt;-</panel_attributes><additional_attributes>300;200;170;200;170;10;10;10</additional_attributes></element><element><id>UMLSequenceAllInOne</id><coordinates><x>11</x><y>3905</y><w>825</w><h>935</h></coordinates><panel_attributes>title=Sequence Diagram VBS (Status Request)
obj=Lifeline Computador~a
obj=Lifeline VBS_Pico:vParserTask~b
obj=Lifeline VBS_Pico:vPotentiometerTask~c

a-&gt;&gt;&gt;b : 1: GET_STATUS; on=b
b-&gt;b+1: 2: Check sysFault Flag

combinedFragment=alt~altStatus b a; b:[sysFault == FALSE]
    b-&gt;&gt;&gt;c : 3: Get currentPot; on=c
    c.&gt;b : 4: return pot; off=c
    b-&gt;b+1: 5: Convert Pot to Volume (cm3)
    b-&gt;&gt;&gt;a : 6: Response: OK + Volume; on=a
    a.&gt;b : 7: ACK; off=a

..=altStatus; b:[sysFault == TRUE]
    b-&gt;b+1: 8: Retrieve sysError Code
    b-&gt;&gt;&gt;a : 9: Response: NOK + ErrorCode (E01/E02/E03); on=a
    a.&gt;b : 10: ACK; off=a
--=altStatus

off=b</panel_attributes><additional_attributes></additional_attributes></element></diagram>